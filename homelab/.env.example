# cp .env.example .env  — .env is gitignored, never commit it (repo is public!)

# Your box's full Tailscale hostname (see `tailscale status` or the admin console)
TS_HOSTNAME=box.tailXXXX.ts.net

# Basic auth for everything (OwnTracks phone app + Zotero WebDAV).
# Generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password-here'
# IMPORTANT: double every $ in the hash ($ -> $$) or docker compose will
# interpolate parts of it as variables and corrupt it.
BASIC_USER=sebastian
BASIC_HASH=$$2a$$14$$replace-me-with-bcrypt-hash
